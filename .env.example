# ══════════════════════════════════════════════════════════════
# PRISM Analyst Platform — Environment Variables
# Copy to .env.local for local development
# ══════════════════════════════════════════════════════════════

# ── API Backend URL ──
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Feature Flags ──
NEXT_PUBLIC_LIVE_API=false
NEXT_PUBLIC_STREAMING=false
NEXT_PUBLIC_AUTH=false

# ── External URLs ──
NEXT_PUBLIC_LANDING_URL=http://localhost:4000
NEXT_PUBLIC_PRISM_URL=http://localhost:3000
